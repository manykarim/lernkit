# Coolify production env for the Lernkit stack.
# Coolify prompts for these at deploy time; never commit the filled-in .env.

# Hostnames (DNS must point at the Coolify box)
DOCS_HOSTNAME=docs.example.com
API_HOSTNAME=api.example.com
GLITCHTIP_HOSTNAME=errors.example.com

# Application
LOG_LEVEL=info
SITE_URL=https://docs.example.com

# Postgres
POSTGRES_DB=lernkit
POSTGRES_USER=lernkit
POSTGRES_PASSWORD=change-me-use-a-strong-secret

# GlitchTip
GLITCHTIP_SECRET_KEY=change-me-generate-a-50-char-random-string
GLITCHTIP_FROM_EMAIL=noreply@example.com
GLITCHTIP_EMAIL_URL=consolemail://
