# Lernkit environment variables — copy to .env for local dev
# Never commit .env (it's in .gitignore).

# Application
LERNKIT_ENV=development
LERNKIT_LOG_LEVEL=info

# API (apps/api)
API_HOST=0.0.0.0
API_PORT=8000

# Astro site (apps/docs)
SITE_URL=http://localhost:4321

# Postgres (infra/docker-compose.yml)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=lernkit
POSTGRES_USER=lernkit
POSTGRES_PASSWORD=lernkit_dev_only

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# GlitchTip (self-hosted error tracking, ADR 0021)
# DSN comes from the GlitchTip UI after creating a project.
SENTRY_DSN=

# Yet Analytics SQL LRS (ADR 0013)
LRS_URL=http://localhost:8080/lrs
LRS_USERNAME=lernkit
LRS_PASSWORD=lernkit_dev_only
