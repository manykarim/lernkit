{
  "name": "@lernkit/tracker",
  "version": "0.0.0",
  "private": true,
  "description": "Unified Tracker interface for SCORM / cmi5 / xAPI with pluggable adapters (ADR 0004).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters/noop": {
      "types": "./dist/adapters/noop.d.ts",
      "import": "./dist/adapters/noop.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@lernkit/config": "workspace:*",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
