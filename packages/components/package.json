{
  "name": "@lernkit/components",
  "version": "0.0.1",
  "description": "React components for Lernkit courses — quiz widgets and runnable-code primitives (Phase 1+).",
  "keywords": ["lernkit", "e-learning", "scorm", "xapi", "quiz", "mcq", "react", "astro-islands"],
  "license": "MIT",
  "author": "The Lernkit contributors",
  "homepage": "https://github.com/manykarim/lernkit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manykarim/lernkit.git",
    "directory": "packages/components"
  },
  "bugs": {
    "url": "https://github.com/manykarim/lernkit/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./quiz": {
      "types": "./dist/quiz/index.d.ts",
      "import": "./dist/quiz/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "prepack": "pnpm build"
  },
  "peerDependencies": {
    "@lernkit/tracker": ">=0.0.1",
    "react": ">=18.0.0 <20.0.0",
    "react-dom": ">=18.0.0 <20.0.0"
  },
  "devDependencies": {
    "@lernkit/tracker": "workspace:*",
    "@testing-library/react": "16.1.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "happy-dom": "15.11.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
