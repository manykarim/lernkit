{
  "name": "@lernkit/packagers",
  "version": "0.0.1",
  "description": "Standards packagers for Lernkit. Phase 1 ships SCORM 1.2; cmi5, SCORM 2004, xAPI bundle, and plain-HTML follow in later phases (ADR 0015).",
  "keywords": [
    "scorm",
    "scorm12",
    "cmi5",
    "xapi",
    "lms",
    "e-learning",
    "packager",
    "imsmanifest",
    "course-authoring",
    "lernkit"
  ],
  "license": "MIT",
  "author": "The Lernkit contributors",
  "homepage": "https://github.com/manykarim/lernkit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manykarim/lernkit.git",
    "directory": "packages/packagers"
  },
  "bugs": {
    "url": "https://github.com/manykarim/lernkit/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./scorm12": {
      "types": "./dist/scorm12/index.d.ts",
      "import": "./dist/scorm12/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-assets.mjs",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "jszip": "3.10.1",
    "nunjucks": "3.2.4"
  },
  "devDependencies": {
    "@types/node": "22.19.17",
    "@types/nunjucks": "3.2.6",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  }
}
