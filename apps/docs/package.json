{
  "name": "@lernkit/docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/copy-pyodide.mjs && node scripts/download-rf-wheels.mjs",
    "dev": "astro dev --host",
    "start": "astro dev --host",
    "prebuild": "node scripts/copy-pyodide.mjs && node scripts/download-rf-wheels.mjs",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "typecheck": "astro check",
    "clean": "rm -rf dist .astro dist-packages public/pyodide",
    "smoke:rf-pyodide": "node tests/integration/rf-pyodide-smoke.mjs",
    "package:scorm12": "node scripts/package-scorm12.mjs",
    "package:scorm12:with-runtime": "INCLUDE_PYODIDE_RUNTIME=1 node scripts/package-scorm12.mjs",
    "package:scorm12:rf-training": "COURSE_ROOT_DIR=rf-training COURSE_ID=rf-training COURSE_TITLE='Robot Framework Training' COURSE_DESCRIPTION='A Lernkit-authored course covering Robot Framework from zero to writing real tests.' COURSE_MASTERY_SCORE=0.7 node scripts/package-scorm12.mjs",
    "package:scorm12:rf-training:with-runtime": "INCLUDE_PYODIDE_RUNTIME=1 COURSE_ROOT_DIR=rf-training COURSE_ID=rf-training COURSE_TITLE='Robot Framework Training' COURSE_DESCRIPTION='A Lernkit-authored course covering Robot Framework from zero to writing real tests.' COURSE_MASTERY_SCORE=0.7 node scripts/package-scorm12.mjs",
    "build:scorm12": "pnpm build && pnpm package:scorm12",
    "build:scorm12:rf-training": "pnpm build && pnpm package:scorm12:rf-training",
    "build:scorm12:rf-training:with-runtime": "pnpm build && pnpm package:scorm12:rf-training:with-runtime"
  },
  "dependencies": {
    "@astrojs/check": "0.9.4",
    "@astrojs/react": "4.3.1",
    "@astrojs/starlight": "0.30.6",
    "@codemirror/autocomplete": "^6.18.4",
    "@codemirror/commands": "^6.7.1",
    "@codemirror/language": "^6.10.6",
    "@codemirror/legacy-modes": "^6.4.2",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.36.1",
    "@lernkit/components": "workspace:*",
    "@lernkit/tracker": "workspace:*",
    "astro": "5.1.1",
    "comlink": "^4.4.2",
    "pyodide": "^0.29.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "sharp": "0.33.5"
  },
  "devDependencies": {
    "@lernkit/config": "workspace:*",
    "@lernkit/packagers": "workspace:*",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.2",
    "typescript": "5.7.2"
  }
}
