{
  "name": "@lernkit/website",
  "version": "0.0.0",
  "private": true,
  "description": "Lernkit framework reference documentation (Docusaurus). Separate from the Astro/Starlight course site under apps/docs.",
  "license": "MIT",
  "scripts": {
    "predev": "node scripts/sync-adrs.mjs",
    "prestart": "node scripts/sync-adrs.mjs",
    "prebuild": "node scripts/sync-adrs.mjs",
    "dev": "docusaurus start",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "preview": "docusaurus serve",
    "serve": "docusaurus serve",
    "clear": "docusaurus clear",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf build .docusaurus node_modules/.cache",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "swizzle": "docusaurus swizzle"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "prism-react-renderer": "^2.4.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.1",
    "@docusaurus/tsconfig": "3.10.1",
    "@docusaurus/types": "3.10.1",
    "@types/react": "^18.0.0",
    "docusaurus-plugin-typedoc": "1.4.2",
    "typedoc": "0.28.19",
    "typedoc-plugin-markdown": "4.11.0",
    "typescript": "6.0.3"
  },
  "browserslist": {
    "production": [">0.5%", "not dead", "not op_mini all"],
    "development": ["last 3 chrome version", "last 3 firefox version", "last 5 safari version"]
  },
  "engines": {
    "node": ">=22.0.0"
  }
